LEGAL_IDENTITY_ENCRYPTION_KEY=base64-encoded-32-byte-key
EMAIL_OTP_DELIVERY_PROVIDER=development
RESEND_API_KEY=
RESEND_FROM_EMAIL=Real Estate Platform <onboarding@resend.dev>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
AUTH_JWT_ACCESS_TOKEN_SECRET=change-me-in-local-env
AUTH_JWT_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_JWT_ISSUER=decentralized-real-estate-auth

# Local development/testing only. Production should set this to false.
AUTH_RETURN_OTP_IN_RESPONSE=true
