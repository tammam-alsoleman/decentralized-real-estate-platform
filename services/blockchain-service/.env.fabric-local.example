SERVICE_NAME=blockchain-service
NODE_ENV=development

GRPC_HOST=0.0.0.0
GRPC_PORT=50055

RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=realestate.events
RABBITMQ_CONTRACT_SUBMISSION_QUEUE=blockchain.contract-submission
RABBITMQ_CONTRACT_SUBMISSION_ROUTING_KEY=property.contract.submission.requested
RABBITMQ_CONTRACT_SUBMITTED_ROUTING_KEY=blockchain.contract.submitted
RABBITMQ_CONTRACT_SUBMISSION_FAILED_ROUTING_KEY=blockchain.contract.submission.failed
RABBITMQ_CONSUMER_ENABLED=false

FABRIC_CHANNEL_NAME=realestatechannel
FABRIC_CHAINCODE_NAME=realestate-contract
FABRIC_MSP_ID=PlatformMSP
FABRIC_PEER_ENDPOINT=localhost:9051
FABRIC_TLS_SERVER_NAME_OVERRIDE=peer0.platform.realestate.local
FABRIC_TLS_CERT_PATH=../../infrastructure/fabric/organizations/peerOrganizations/platform.realestate.local/peers/peer0.platform.realestate.local/tls/ca.crt
FABRIC_CERT_PATH=../../infrastructure/fabric/organizations/peerOrganizations/platform.realestate.local/users/Admin@platform.realestate.local/msp/signcerts/cert.pem
FABRIC_PRIVATE_KEY_PATH=../../infrastructure/fabric/organizations/peerOrganizations/platform.realestate.local/users/Admin@platform.realestate.local/msp/keystore/<replace-with-current-private-key-file>_sk
